<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.linkedin.pragent</string>
    
    <!-- This forces the Python process to run in Indian Standard Time (IST) -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>TZ</key>
        <string>America/New_York</string>
        <!-- If your Python is installed via Homebrew, we need to ensure the PATH is correct -->
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>ProgramArguments</key>
    <array>
        <string>python3</string>
        <string>main.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/path/to/linkedin_pr_agent</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/path/to/linkedin_pr_agent/agent.out.log</string>
    
    <key>StandardErrorPath</key>
    <string>/path/to/linkedin_pr_agent/agent.err.log</string>
</dict>
</plist>
